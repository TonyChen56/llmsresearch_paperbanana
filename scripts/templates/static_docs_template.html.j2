<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} 文档</title>
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif; background: #f7f8fa; color: #1f2937; }
    .layout { display: flex; min-height: 100vh; }
    .sidebar { width: 300px; background: #fff; border-right: 1px solid #e5e7eb; padding: 24px 0; position: sticky; top: 0; height: 100vh; overflow-y: auto; }
    .brand { padding: 0 24px 16px; border-bottom: 1px solid #e5e7eb; margin-bottom: 12px; }
    .brand h1 { margin: 0; font-size: 20px; color: #2563eb; }
    .brand p { margin: 6px 0 0; color: #6b7280; font-size: 13px; }
    .nav { padding: 8px 16px; }
    .nav a { display: block; padding: 8px 10px; margin-bottom: 4px; border-radius: 8px; color: #374151; text-decoration: none; font-size: 14px; }
    .nav a:hover { background: #eff6ff; color: #1d4ed8; }
    .main { flex: 1; padding: 24px; max-width: 1200px; }
    .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 20px; margin-bottom: 16px; }
    .card h2 { margin: 0 0 10px; }
    .muted { color: #6b7280; font-size: 13px; }
    .endpoint-title { margin: 0 0 10px; font-size: 18px; }
    .badge { display: inline-block; font-size: 12px; font-weight: 600; border-radius: 999px; padding: 4px 10px; margin-right: 8px; }
    .get { background: #dcfce7; color: #166534; }
    .post { background: #dbeafe; color: #1e3a8a; }
    .put { background: #fef3c7; color: #92400e; }
    .patch { background: #f3e8ff; color: #6b21a8; }
    .delete { background: #fee2e2; color: #991b1b; }
    .path { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; background: #f3f4f6; border-radius: 6px; padding: 2px 8px; }
    pre { background: #111827; color: #e5e7eb; border-radius: 10px; padding: 12px; overflow-x: auto; font-size: 13px; }
    code { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    th, td { border: 1px solid #e5e7eb; padding: 8px; text-align: left; }
    th { background: #f9fafb; }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="brand">
        <h1>{{ title }}</h1>
        <p>版本 {{ version }}</p>
        <p>静态文档自动生成</p>
      </div>
      <nav class="nav">
        <a href="#overview">概览</a>
        {% for ep in endpoints %}
        <a href="#{{ ep.anchor }}">{{ ep.method_upper }} {{ ep.path }}</a>
        {% endfor %}
      </nav>
    </aside>
    <main class="main">
      <section id="overview" class="card">
        <h2>API 概览</h2>
        <p class="muted">生成时间：{{ generated_at }}</p>
        <p>{{ summary }}</p>
      </section>

      {% for ep in endpoints %}
      <section id="{{ ep.anchor }}" class="card">
        <h3 class="endpoint-title">
          <span class="badge {{ ep.method_class }}">{{ ep.method_upper }}</span>
          <span class="path">{{ ep.path }}</span>
        </h3>
        {% if ep.summary %}<p><strong>{{ ep.summary }}</strong></p>{% endif %}
        {% if ep.description %}<p>{{ ep.description }}</p>{% endif %}
        {% if ep.tags and ep.tags|length > 0 %}
        <p class="muted">标签：{{ ep.tags|join(", ") }}</p>
        {% endif %}

        {% if ep.request_content_types and ep.request_content_types|length > 0 %}
        <p><strong>请求 Content-Type：</strong>{{ ep.request_content_types|join(", ") }}</p>
        {% endif %}

        {% if ep.request_example %}
        <p><strong>请求示例：</strong></p>
        <pre><code>{{ ep.request_example }}</code></pre>
        {% endif %}

        {% if ep.responses and ep.responses|length > 0 %}
        <p><strong>响应：</strong></p>
        <table>
          <thead>
            <tr><th>状态码</th><th>说明</th></tr>
          </thead>
          <tbody>
            {% for rsp in ep.responses %}
            <tr><td>{{ rsp.code }}</td><td>{{ rsp.description }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
        {% endif %}

        <p><strong>cURL：</strong></p>
        <pre><code>{{ ep.curl_example }}</code></pre>
      </section>
      {% endfor %}
    </main>
  </div>
</body>
</html>
