# PaperBanana Environment Variables
# Copy this file to .env and fill in your keys.

# OpenAI (alternative): https://platform.openai.com/api-keys
# To use OpenAI instead of Gemini, uncomment these:
# VLM_PROVIDER=openai
# IMAGE_PROVIDER=openai_imagen
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VLM_MODEL=gpt-5.2
OPENAI_IMAGE_MODEL=gpt-image-1.5
# For Azure OpenAI / Foundry, point to your endpoint:
#   OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/v1

# Google Gemini (free, no credit card): https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# KIE（Gemini 2.5 Flash + Nano Banana）密钥申请地址：https://kie.ai/api-key
# 使用 KIE 时，请设置：
# VLM_PROVIDER=kie
# IMAGE_PROVIDER=kie_nano_banana
KIE_API_KEY=

# API 服务鉴权（必填）：所有 /api/v1/tasks/* 接口都需要 Bearer Token
PAPERBANANA_API_TOKEN=

# API 任务并发与状态保留时间（可选）
API_MAX_CONCURRENT_TASKS=3
API_TASK_TTL_MINUTES=120

# ── SSL ────────────────────────────────────────────────────────────
# Set to true to skip SSL certificate verification (corporate proxies)
SKIP_SSL_VERIFICATION=false
